<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<VBox spacing="20" alignment="CENTER" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.school.controller.AuthController"
      style="-fx-padding: 40; -fx-background-color: #0d1117;">

    <Label text="🏫 School Management System"
           style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #58a6ff;"/>
    <Label text="Please log in or create an account"
           style="-fx-font-size: 13; -fx-text-fill: #8b949e;"/>

    <TabPane tabClosingPolicy="UNAVAILABLE"
             style="-fx-tab-min-width: 120; -fx-background-color: transparent;">

        <!-- ── LOGIN TAB ── -->
        <Tab text="Login">
            <VBox spacing="12" style="-fx-padding: 24; -fx-background-color: #161b22; -fx-background-radius: 8;">
                <TextField fx:id="loginUsernameField" promptText="Username"
                           style="-fx-background-color: #0d1117; -fx-text-fill: #c9d1d9; -fx-border-color: #30363d; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 8 12;"/>
                <PasswordField fx:id="loginPasswordField" promptText="Password"
                              style="-fx-background-color: #0d1117; -fx-text-fill: #c9d1d9; -fx-border-color: #30363d; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 8 12;"/>
                <Button text="Login" onAction="#handleLogin" maxWidth="Infinity"
                        style="-fx-background-color: #238636; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10; -fx-background-radius: 6; -fx-cursor: hand;"/>
                <Label text="Default: admin / admin123" style="-fx-text-fill: #8b949e; -fx-font-size: 11;"/>
            </VBox>
        </Tab>

        <!-- ── REGISTER TAB ── -->
        <Tab text="Register">
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #161b22;">
                <VBox spacing="10" style="-fx-padding: 24; -fx-background-color: #161b22;">
                    <TextField fx:id="regUsername" promptText="Username (3–20 chars)"
                               style="-fx-background-color: #0d1117; -fx-text-fill: #c9d1d9; -fx-border-color: #30363d; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 8 12;"/>
                    <PasswordField fx:id="regPassword" promptText="Password (min 6 chars, incl. a number)"
                                  style="-fx-background-color: #0d1117; -fx-text-fill: #c9d1d9; -fx-border-color: #30363d; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 8 12;"/>
                    <TextField fx:id="regFullName" promptText="Full Name"
                               style="-fx-background-color: #0d1117; -fx-text-fill: #c9d1d9; -fx-border-color: #30363d; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 8 12;"/>
                    <ComboBox fx:id="regRole" promptText="Account Type" maxWidth="Infinity"
                              onAction="#toggleLinkedField"
                              style="-fx-background-color: #0d1117; -fx-border-color: #30363d; -fx-border-radius: 4;">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="ADMIN"/>
                                <String fx:value="TEACHER"/>
                                <String fx:value="STUDENT"/>
                            </FXCollections>
                        </items>
                    </ComboBox>
                    <TextField fx:id="regLinkedId" promptText="Student ID or Teacher Name (if applicable)"
                               visible="false" managed="false"
                               style="-fx-background-color: #0d1117; -fx-text-fill: #c9d1d9; -fx-border-color: #30363d; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 8 12;"/>
                    <Button text="Create Account" onAction="#handleSignup" maxWidth="Infinity"
                            style="-fx-background-color: #1f6feb; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10; -fx-background-radius: 6; -fx-cursor: hand;"/>
                </VBox>
            </ScrollPane>
        </Tab>
    </TabPane>

    <Label fx:id="statusLabel" wrapText="true" maxWidth="380"
           style="-fx-font-size: 12; -fx-text-fill: #f85149;"/>
</VBox>
